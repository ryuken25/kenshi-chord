# =============================================================================
# KenshiChord .gitignore
# Repo-level ignores. Heavy ML weights, downloaded media, dev DBs, and venvs
# stay out of git. See README.md → "Heavy models" for the download locations.
# =============================================================================

# ---- OS / IDE ----
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~
*.code-workspace

# ---- Local secrets / env ----
.env
.env.local
*.pem
*.key

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
build/
dist/
.mypy.ini
.tox/

# ---- Virtualenvs ----
venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

# ---- Data / dev DB / downloaded audio (auto-created on first run) ----
data/kenshi.db
data/kenshi.db-journal
data/kenshi.db-wal
data/kenshi.db-shm
data/audio/*.wav
data/audio/*.mp3
data/audio/*.m4a
data/audio/*.webm
data/audio/*.opus
data/audio/*.flac
# BTC pipeline staging dirs (created per-song by smartfix_auto.btc_detect)
data/audio/btc_in_*/
data/audio/btc_out_*/
# Demucs stem outputs
data/audio/*.vocals.wav
data/audio/*.drums.wav
data/audio/*.bass.wav
data/audio/*.other.wav

# ---- ML model weights (HEAVY — see README.md for download) ----
# BTC-ISMIR19 pretrained checkpoints (each ~12MB)
backend/BTC-ISMIR19/test/btc_model.pt
backend/BTC-ISMIR19/test/btc_model_large_voca.pt
# Generic model binaries
*.pt
*.pth
*.pth.tar
*.ckpt
*.onnx
*.h5
*.hdf5
*.safetensors
*.bin
*.tflite
*.gguf
# HuggingFace / torch hub caches (also outside-repo, but defensively)
.cache/
models_cache/
hf_cache/

# ---- Logs / temp ----
*.log
logs/
*.tmp
*.bak

# ---- Frontend ----
# (no build step — keep node_modules out if you ever add one)
node_modules/
frontend/dist/
frontend/build/
.parcel-cache/
.vite/
